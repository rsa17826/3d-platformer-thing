; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="3d test"
run/main_scene="uid://0f4jvws0q0l4"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

global="*res://global.gd"
ToastParty="*uid://c3o3pswn4rkt1"

[beautifier]

theme_script="res://addons/godot_beautifier/themes/Nana7mi/theme.gd"
default_settings={
"rendering/environment/defaults/default_clear_color": Color(0.3, 0.3, 0.3, 1)
}

[display]

window/size/mode=4
window/subwindows/embed_subwindows=false

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_beautifier/plugin.cfg", "res://addons/gridmap-plus/plugin.cfg", "res://addons/log/plugin.cfg", "res://addons/toastparty/plugin.cfg")

